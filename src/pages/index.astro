---
import Base from "../layouts/Base.astro";
import { Code } from "astro:components";

const quickStartCode = `import donglora as dl

ser = dl.connect()
dl.send(ser, "SetConfig", config=dl.DEFAULT_CONFIG)
dl.send(ser, "StartRx")

while pkt := dl.recv(ser):
    print(f'{pkt["rssi"]:4d}dBm {pkt["snr"]:3d}dB {pkt["payload"].hex()}')`;

// Shiki theme tuned to match the site's green-accent dark palette
const siteTheme = {
  name: "donglora",
  type: "dark" as const,
  colors: {
    "editor.background": "#12121a",
    "editor.foreground": "#e0e0e8",
  },
  settings: [
    { scope: ["comment"], settings: { foreground: "#555570", fontStyle: "italic" } },
    { scope: ["keyword", "storage", "keyword.control"], settings: { foreground: "#6ee7b7" } },
    { scope: ["string", "string.quoted"], settings: { foreground: "#fbbf24" } },
    { scope: ["constant.numeric", "constant.language"], settings: { foreground: "#c4b5fd" } },
    { scope: ["entity.name.function", "meta.function-call"], settings: { foreground: "#60a5fa" } },
    { scope: ["support.function", "support.function.builtin"], settings: { foreground: "#60a5fa" } },
    { scope: ["variable", "variable.other"], settings: { foreground: "#e0e0e8" } },
    { scope: ["variable.parameter", "variable.other.readwrite"], settings: { foreground: "#e0e0e8" } },
    { scope: ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison"], settings: { foreground: "#6ee7b7" } },
    { scope: ["punctuation", "meta.brace"], settings: { foreground: "#8888a0" } },
    { scope: ["punctuation.definition.string", "punctuation.section"], settings: { foreground: "#fbbf24" } },
    { scope: ["entity.name.import", "entity.name.module"], settings: { foreground: "#34d399" } },
    { scope: ["support.type", "entity.name.type"], settings: { foreground: "#60a5fa" } },
    { scope: ["constant.other", "variable.other.constant"], settings: { foreground: "#c4b5fd" } },
    { scope: ["meta.function-call.arguments", "variable.parameter.function-call"], settings: { foreground: "#e0e0e8" } },
    { scope: ["meta.attribute", "entity.other.attribute-name"], settings: { foreground: "#8888a0" } },
  ],
};
---

<Base title="DongLoRa — Protocol-agnostic LoRa over USB">
  <!-- Early development banner -->
  <div class="bg-warn/10 border border-warn/30 rounded p-4 mb-8">
    <p class="text-warn text-sm font-medium mb-1">Early development</p>
    <p class="text-text-muted text-sm">
      DongLoRa is a tool for building tools. It assumes familiarity with LoRa, serial protocols,
      and programming. APIs may change. If you're looking for a ready-made mesh device, check out
      <a href="https://meshtastic.org" class="text-accent hover:text-accent-bright" target="_blank" rel="noopener noreferrer">Meshtastic</a> or
      <a href="https://meshcore.co.uk" class="text-accent hover:text-accent-bright" target="_blank" rel="noopener noreferrer">MeshCore</a>.
    </p>
  </div>

  <!-- Hero -->
  <section class="py-16 text-center">
    <h1 class="font-mono text-5xl sm:text-6xl font-bold text-accent mb-4">DongLoRa</h1>
    <p class="text-text-dim text-sm mb-3 italic">/ˈdɒŋ.ɡəl.ɔːr.ə/ — dongle + LoRa</p>
    <p class="text-xl text-text-muted max-w-2xl mx-auto mb-2">
      Protocol-agnostic LoRa over USB.
    </p>
    <p class="text-lg text-text-dim max-w-xl mx-auto mb-8">
      Plug in. Talk radio.
    </p>
    <a
      href="/flash"
      class="inline-block bg-accent text-bg font-mono font-medium px-6 py-3 rounded hover:bg-accent-bright transition-colors"
    >
      Flash Your Board
    </a>
  </section>

  <!-- What is it -->
  <section class="py-12 max-w-3xl mx-auto">
    <h2 class="font-mono text-2xl font-bold mb-6 text-text">What is it?</h2>
    <p class="text-text-muted leading-relaxed mb-4">
      Flash firmware onto a LoRa board once and it becomes a dumb USB radio. It doesn't know or
      care what protocol you're running — it just moves bytes between the air and your computer.
    </p>
    <p class="text-text-muted leading-relaxed">
      Everything else — routing, encryption, display, response logic — happens in your code,
      in Python, Rust, or whatever you want — with the feedback loop of a scripting
      environment instead of a flash-and-pray embedded workflow.
    </p>
  </section>

  <hr class="border-border my-4" />

  <!-- Quick Start -->
  <section class="py-12 max-w-3xl mx-auto">
    <h2 class="font-mono text-2xl font-bold mb-6 text-text">Quick Start</h2>
    <ol class="space-y-6">
      <li class="flex gap-4">
        <span class="font-mono text-accent font-bold text-lg shrink-0">1.</span>
        <div>
          <p class="font-medium text-text">Flash the firmware</p>
          <p class="text-sm text-text-muted">
            Use the <a href="/flash" class="text-accent hover:text-accent-bright">web flasher</a> or
            flash from the command line.
          </p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-accent font-bold text-lg shrink-0">2.</span>
        <div>
          <p class="font-medium text-text">Install a client library</p>
          <pre
            class="font-mono text-sm text-accent bg-bg-card border border-border px-4 py-2 rounded mt-2"
          >pip install donglora</pre>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="font-mono text-accent font-bold text-lg shrink-0">3.</span>
        <div>
          <p class="font-medium text-text">Listen for packets</p>
          <div class="mt-2 rounded border border-border overflow-hidden relative group" id="code-block">
            <button
              id="highlight-toggle"
              class="absolute top-2 right-2 text-text-dim hover:text-accent transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
              title="Toggle syntax highlighting"
              aria-label="Toggle syntax highlighting"
            >
              <svg id="toggle-icon-on" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
              <svg id="toggle-icon-off" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </button>
            <div id="code-highlighted">
              <Code code={quickStartCode} lang="python" theme={siteTheme} />
            </div>
            <pre id="code-plain" class="hidden font-mono text-sm text-accent px-4 py-4" style="background-color: var(--color-bg-card);">{quickStartCode}</pre>
          </div>
          <script is:inline>
            document.getElementById('highlight-toggle').addEventListener('click', () => {
              const h = document.getElementById('code-highlighted');
              const p = document.getElementById('code-plain');
              const iconOn = document.getElementById('toggle-icon-on');
              const iconOff = document.getElementById('toggle-icon-off');
              h.classList.toggle('hidden');
              p.classList.toggle('hidden');
              iconOn.classList.toggle('hidden');
              iconOff.classList.toggle('hidden');
            });
          </script>
        </div>
      </li>
    </ol>
  </section>

  <hr class="border-border my-4" />

  <!-- What can you do -->
  <section class="py-12 max-w-3xl mx-auto">
    <h2 class="font-mono text-2xl font-bold mb-6 text-text">What can you do with it?</h2>
    <p class="text-text-muted leading-relaxed mb-6">
      Connect your code directly to a LoRa radio over USB — or run the multiplexer and let
      multiple programs share a single dongle at the same time.
    </p>
    <pre
      class="font-mono text-sm text-accent bg-bg-card border border-border p-6 rounded overflow-x-auto mb-8"
    >your code ──► client lib ──► USB ──► DongLoRa radio

your code ──► client lib ──┐
your code ──► client lib ──┼──► mux ──► USB ──► DongLoRa radio
your code ──► client lib ──┘</pre>
    <p class="text-text-muted leading-relaxed mb-6">
      Because the firmware is protocol-agnostic, a DongLoRa dongle works with any LoRa network
      — Meshtastic, MeshCore, custom protocols, or raw packets.
    </p>
    <div class="space-y-4">
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Interact with mesh networks</h3>
        <p class="text-sm text-text-muted">
          Send and receive packets on Meshtastic, MeshCore, or any other LoRa protocol from a
          laptop, desktop, or Raspberry Pi. Write scripts that interact with mesh traffic
          programmatically.
        </p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Build bots and automations</h3>
        <p class="text-sm text-text-muted">
          Write a chatbot that receives messages over LoRa and responds via an LLM. Build an
          alert system. Log every packet on a frequency. All from Python or Rust on a server.
        </p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Bridge distant networks</h3>
        <p class="text-sm text-text-muted">
          The bridge application connects to local LoRa traffic, encrypts it, and relays it to
          other bridges over the internet. Two bridges in different cities extend a mesh network's
          range by thousands of miles.
        </p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Prototype without embedded development</h3>
        <p class="text-sm text-text-muted">
          Test a LoRa idea in Python in an afternoon. Change frequency, bandwidth, spreading factor
          — all from your code. Iterate fast. No cross-compilation, no JTAG, no boot loops.
        </p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Analyze RF traffic</h3>
        <p class="text-sm text-text-muted">
          Sniff, decode, and log every packet on a frequency. Useful for debugging mesh deployments,
          understanding channel utilization, or reverse-engineering protocols.
        </p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Deploy headless gateways</h3>
        <p class="text-sm text-text-muted">
          A Raspberry Pi with a dongle plugged in is a LoRa gateway. Add the mux and you can run
          multiple services on a single radio — a mesh node, a packet logger, and a bridge, all at
          once.
        </p>
      </div>
    </div>
  </section>

  <hr class="border-border my-4" />

  <!-- Supported Boards -->
  <section class="py-12">
    <h2 class="font-mono text-2xl font-bold mb-6 text-text">Supported Boards</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Heltec V3</h3>
        <p class="text-sm text-text-muted">ESP32-S3 &middot; SX1262</p>
        <p class="text-xs text-accent mt-2 font-mono">Web Flash</p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Heltec V4</h3>
        <p class="text-sm text-text-muted">ESP32-S3 &middot; SX1262</p>
        <p class="text-xs text-accent mt-2 font-mono">Web Flash</p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">RAK WisBlock 4631</h3>
        <p class="text-sm text-text-muted">nRF52840 &middot; SX1262</p>
        <p class="text-xs text-info mt-2 font-mono">UF2 Download</p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Wio Tracker L1</h3>
        <p class="text-sm text-text-muted">nRF52840 &middot; SX1262</p>
        <p class="text-xs text-info mt-2 font-mono">UF2 Download</p>
      </div>
      <div class="bg-bg-card border border-border p-5 rounded">
        <h3 class="font-mono font-medium text-text mb-2">Waveshare RP2040-LoRa</h3>
        <p class="text-sm text-text-muted">RP2040 &middot; SX1262</p>
        <p class="text-xs text-info mt-2 font-mono">UF2 Download</p>
      </div>
    </div>
  </section>

  <hr class="border-border my-4" />

  <!-- Repositories -->
  <section class="py-12">
    <h2 class="font-mono text-2xl font-bold mb-6 text-text">Repositories</h2>

    <!-- Firmware -->
    <h3 class="font-mono text-sm text-text-dim uppercase tracking-wider mb-1">Firmware</h3>
    <p class="text-sm text-text-muted mb-3">The code that runs on the LoRa board itself. Owns the radio hardware, speaks USB.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      <a
        href="https://github.com/donglora/firmware"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">firmware</span>
        <p class="text-sm text-text-muted mt-1">Embedded firmware for LoRa boards (Rust, no_std, Embassy)</p>
      </a>
    </div>

    <!-- Client Libraries -->
    <h3 class="font-mono text-sm text-text-dim uppercase tracking-wider mb-1">Client Libraries</h3>
    <p class="text-sm text-text-muted mb-3">Run on your computer. Handle USB discovery, protocol framing, and encoding so you just call <code class="font-mono text-xs text-accent">send()</code> and <code class="font-mono text-xs text-accent">receive()</code>.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      <a
        href="https://github.com/donglora/client-rs"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">client-rs</span>
        <p class="text-sm text-text-muted mt-1">Rust client library &mdash; <code class="font-mono text-xs text-accent">donglora-client</code> on crates.io</p>
      </a>
      <a
        href="https://github.com/donglora/client-py"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">client-py</span>
        <p class="text-sm text-text-muted mt-1">Python client library &mdash; <code class="font-mono text-xs text-accent">donglora</code> on PyPI</p>
      </a>
    </div>

    <!-- Multiplexer -->
    <h3 class="font-mono text-sm text-text-dim uppercase tracking-wider mb-1">Multiplexer</h3>
    <p class="text-sm text-text-muted mb-3">Optional daemon that lets multiple programs share a single dongle at the same time.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      <a
        href="https://github.com/donglora/mux-rs"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">mux-rs</span>
        <p class="text-sm text-text-muted mt-1">USB multiplexer daemon (Rust)</p>
      </a>
      <a
        href="https://github.com/donglora/mux-py"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">mux-py</span>
        <p class="text-sm text-text-muted mt-1">USB multiplexer daemon &mdash; <code class="font-mono text-xs text-accent">donglora-mux</code> on PyPI</p>
      </a>
    </div>

    <!-- Applications -->
    <h3 class="font-mono text-sm text-text-dim uppercase tracking-wider mb-1">Applications</h3>
    <p class="text-sm text-text-muted mb-3">Real programs built on the layers above. Examples of what you can do with a DongLoRa dongle.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a
        href="https://github.com/donglora/bridge"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">bridge</span>
        <p class="text-sm text-text-muted mt-1">P2P LoRa bridge &mdash; relays encrypted packets across the internet (Rust)</p>
      </a>
      <a
        href="https://github.com/donglora/ai-bot"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">ai-bot</span>
        <p class="text-sm text-text-muted mt-1">MeshCore AI chatbot &mdash; mesh name "Orac" (Python)</p>
      </a>
      <a
        href="https://github.com/donglora/examples"
        class="bg-bg-card border border-border p-4 rounded hover:border-border-bright transition-colors block"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="font-mono text-accent text-sm">examples</span>
        <p class="text-sm text-text-muted mt-1">Ready-to-run scripts &mdash; receive, transmit, ping-pong, bridge (Python)</p>
      </a>
    </div>
  </section>

</Base>
